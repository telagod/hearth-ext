{
  "name": "hearth",
  "version": "0.0.1",
  "private": true,
  "description": "Hearth — Personal knowledge companion. Your reading, remembered. Quietly.",
  "license": "MIT",
  "author": "telagod",
  "homepage": "https://telagod.github.io/hearth-ext/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telagod/hearth-ext.git"
  },
  "bugs": {
    "url": "https://github.com/telagod/hearth-ext/issues"
  },
  "keywords": [
    "knowledge-management",
    "browser-extension",
    "manifest-v3",
    "chrome-extension",
    "sqlite-wasm",
    "fts5",
    "simhash",
    "lsh",
    "local-first",
    "byok",
    "llm",
    "anthropic",
    "openai",
    "ollama",
    "rag",
    "highlight",
    "annotation",
    "second-brain",
    "obsidian",
    "skill-engine",
    "open-source"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,css,md,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "mockup": "vite --config vite.mockup.config.ts",
    "package": "npm run build && cd dist && zip -r ../hearth-${npm_package_version}.zip ./*"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@resvg/resvg-js": "^2.6.2",
    "@sqlite.org/sqlite-wasm": "^3.46.0-build1",
    "cron-parser": "^4.9.0",
    "dompurify": "^3.1.7",
    "framer-motion": "^11.11.0",
    "fuse.js": "^7.0.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.7.2",
    "marked": "^14.1.3",
    "minijinja-js": "^2.0.0",
    "pdfjs-dist": "^4.4.168",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tesseract.js": "^5.1.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/chrome": "^0.0.270",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^12.10.0",
    "eslint": "^9.12.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-static-copy": "^2.0.0",
    "vitest": "^2.1.2"
  }
}
